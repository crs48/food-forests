---
// Organic SVG section divider. Fill it with the *next* section's colour so the
// boundary reads as a soft transition. `preserveAspectRatio="none"` stretches
// it across every breakpoint.
interface Props {
  variant?: 'wave' | 'hill' | 'scallop';
  fill?: string; // any CSS color / var()
  flip?: boolean;
  class?: string;
  height?: number;
}
const { variant = 'wave', fill = 'var(--bg)', flip = false, class: className = '', height = 60 } = Astro.props;

const shapes: Record<string, string> = {
  wave: 'M0,40 C240,90 480,0 720,30 C960,60 1200,20 1440,50 L1440,120 L0,120 Z',
  hill: 'M0,70 C360,10 1080,10 1440,70 L1440,120 L0,120 Z',
  scallop:
    'M0,60 Q60,20 120,60 T240,60 T360,60 T480,60 T600,60 T720,60 T840,60 T960,60 T1080,60 T1200,60 T1320,60 T1440,60 L1440,120 L0,120 Z',
};
const d = shapes[variant] ?? shapes.wave;
---
<div class={`divider ${className}`} aria-hidden="true" style={`--divider-fill:${fill};height:${height}px;${flip ? 'transform:scaleX(-1)' : ''}`}>
  <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d={d} fill="var(--divider-fill)"></path>
  </svg>
</div>

<style>
  .divider {
    position: relative;
    width: 100%;
    line-height: 0;
    margin-bottom: -1px;
    pointer-events: none;
  }
  .divider svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
