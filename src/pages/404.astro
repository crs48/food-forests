---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout title="Lost in the undergrowth" description="This page has gone to seed." noindex={true}>
  <section class="nf">
    <span class="ico"><Icon name="sprout" size={44} stroke={1.5} /></span>
    <p class="code">404</p>
    <h1>This path has grown over</h1>
    <p class="sub">
      The page you were looking for isn't here — perhaps it went to seed. Let's
      get you back to solid ground.
    </p>
    <div class="btns">
      <Button href="/" variant="primary" icon="arrow-right">Back to the clearing</Button>
      <Button href="/learn" variant="ghost">Browse the library</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    max-width: 34rem;
    margin: 0 auto;
    padding: clamp(3rem, 10vw, 6rem) 1.25rem;
    text-align: center;
  }
  .ico {
    display: inline-grid;
    place-items: center;
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    color: var(--primary-ink);
    background: var(--primary);
    margin-bottom: 1rem;
  }
  .code {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: color-mix(in oklab, var(--primary) 40%, transparent);
    margin: 0;
    line-height: 1;
  }
  .nf h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0.4rem 0 0.8rem; }
  .sub { color: var(--muted-fg); font-size: 1.1rem; margin: 0 0 1.8rem; }
  .btns { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
</style>
