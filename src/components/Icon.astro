---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={px}
  height={px}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon ${className}`}
  aria-hidden={rest['aria-hidden'] ?? true}
  set:html={d}
/>
