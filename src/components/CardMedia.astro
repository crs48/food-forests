---
import Icon from './Icon.astro';
// Decorative gradient "media" band for cards without a photograph yet.
// Swap for astro:assets <Image /> once real imagery is curated (see /credits).
interface Props {
  icon?: string;
  label?: string;
  seed?: string;
  height?: number;
}
const { icon = 'leaf', label, seed = '', height = 150 } = Astro.props;

// Deterministic gradient angle from the seed string, so each card differs a
// little but stays stable across builds (no Math.random at build time).
let h = 0;
for (const ch of seed) h = (h * 31 + ch.charCodeAt(0)) % 360;
const angle = 90 + (h % 90);
const gradients = [
  'linear-gradient(var(--a), color-mix(in oklab, var(--color-leaf) 55%, var(--color-cream)), color-mix(in oklab, var(--color-forest) 60%, var(--color-honey)))',
  'linear-gradient(var(--a), color-mix(in oklab, var(--color-honey) 45%, var(--color-cream)), color-mix(in oklab, var(--color-terracotta) 55%, var(--color-clay)))',
  'linear-gradient(var(--a), color-mix(in oklab, var(--color-sky) 45%, var(--color-cream)), color-mix(in oklab, var(--color-forest) 55%, var(--color-leaf)))',
];
const g = gradients[h % gradients.length];
---
<div class="media" style={`--a:${angle}deg;height:${height}px;background:${g}`} aria-hidden="true">
  <span class="glyph"><Icon name={icon} size={40} stroke={1.5} /></span>
  {label && <span class="tag">{label}</span>}
</div>

<style>
  .media {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in oklab, white 82%, transparent);
  }
  .media::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.5) 0, transparent 40%);
  }
  .glyph {
    display: grid;
    place-items: center;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: color-mix(in oklab, white 22%, transparent);
    backdrop-filter: blur(2px);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, white 30%, transparent);
  }
  .tag {
    position: absolute;
    left: 0.85rem;
    bottom: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    color: white;
    background: color-mix(in oklab, black 35%, transparent);
  }
</style>
