---
import Icon from './Icon.astro';
import { footerNav, site } from '../lib/site.ts';
import { href } from '../lib/url.ts';

const year = 2026;
const repo = 'https://github.com/crs48/food-forests';
---
<footer class="site-footer">
  <div class="inner">
    <div class="col brand-col">
      <a class="brand" href={href('/')}>
        <span class="mark"><Icon name="sprout" size={20} stroke={2} /></span>
        {site.name}
      </a>
      <p class="tagline">{site.tagline}</p>
      <p class="fine">
        A labour of love for regenerative land, open food, and hopeful futures.
      </p>
    </div>

    <nav class="col" aria-label="Footer">
      <h2>Explore</h2>
      <ul>
        {footerNav.map((item) => (
          <li><a href={href(item.path)}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="col">
      <h2>This project</h2>
      <ul>
        <li>
          <a href={repo} target="_blank" rel="noopener noreferrer" class="ext">
            <Icon name="github" size={16} /> Source on GitHub
          </a>
        </li>
        <li><a href={href('/credits')}>Image credits</a></li>
        <li><a href={href('/about')}>About &amp; mission</a></li>
      </ul>
    </div>
  </div>

  <div class="baseline">
    <p>© {year} {site.name}. Content shared in the spirit of the commons.</p>
    <p>Built with Astro &amp; Tailwind · Grown with patience.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    background: var(--footer-bg);
    color: var(--footer-fg);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3.5rem 1.25rem 2rem;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--footer-fg);
    text-decoration: none;
  }
  .mark {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: color-mix(in oklab, var(--color-leaf) 70%, white);
    color: #10201a;
  }
  .tagline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin: 0.9rem 0 0.4rem;
    color: color-mix(in oklab, var(--footer-fg) 90%, transparent);
  }
  .fine {
    margin: 0;
    font-size: 0.9rem;
    max-width: 24rem;
    color: color-mix(in oklab, var(--footer-fg) 70%, transparent);
  }
  .col h2 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--footer-fg) 65%, transparent);
    margin: 0 0 0.9rem;
  }
  .col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .col a {
    color: color-mix(in oklab, var(--footer-fg) 92%, transparent);
    text-decoration: none;
    font-size: 0.98rem;
  }
  .col a:hover {
    color: color-mix(in oklab, var(--color-honey) 80%, white);
  }
  .ext {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .baseline {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.4rem 1.25rem 2.4rem;
    border-top: 1px solid color-mix(in oklab, var(--footer-fg) 15%, transparent);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    justify-content: space-between;
    font-size: 0.85rem;
    color: color-mix(in oklab, var(--footer-fg) 60%, transparent);
  }
  .baseline p { margin: 0; }

  @media (min-width: 720px) {
    .inner {
      grid-template-columns: 1.6fr 1fr 1fr;
    }
  }
</style>
