---
interface Props {
  width?: 'narrow' | 'default' | 'wide';
  bg?: 'bg' | 'surface' | 'surface-2' | 'none';
  class?: string;
  id?: string;
  pad?: 'sm' | 'md' | 'lg';
}
const { width = 'default', bg = 'none', class: className = '', id, pad = 'lg' } = Astro.props;
const maxes = { narrow: '46rem', default: '72rem', wide: '82rem' };
const bgVar =
  bg === 'none' ? 'transparent' : bg === 'bg' ? 'var(--bg)' : `var(--${bg})`;
const pads = { sm: '2rem', md: '3.5rem', lg: '5rem' };
---
<section id={id} class={`section ${className}`} style={`--bg-color:${bgVar};--pad:${pads[pad]}`}>
  <div class="wrap" style={`--max:${maxes[width]}`}>
    <slot />
  </div>
</section>

<style>
  .section {
    background: var(--bg-color);
    padding-block: var(--pad);
  }
  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding-inline: 1.25rem;
  }
</style>
